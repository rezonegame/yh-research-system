{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Challenger Tasks Output",
  "description": "Schema for tasks generated by the Challenger in each self-play iteration.",
  "type": "object",
  "required": ["iteration", "tasks"],
  "properties": {
    "iteration": {
      "type": "integer",
      "minimum": 1,
      "description": "Current iteration number (1-indexed)."
    },
    "tasks": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": {
        "type": "object",
        "required": ["id", "weakness_category", "target_section", "task_description", "binary_rubric", "expected_difficulty"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^T[1-3]$",
            "description": "Task identifier within this iteration."
          },
          "weakness_category": {
            "type": "string",
            "enum": [
              "ambiguous_triggers",
              "missing_failure_modes",
              "incomplete_workflows",
              "vague_instructions",
              "missing_checkpoints",
              "over_broad_rules"
            ],
            "description": "The skill weakness category this task probes."
          },
          "target_section": {
            "type": "string",
            "description": "Which section of SKILL.md this task targets."
          },
          "task_description": {
            "type": "string",
            "minLength": 20,
            "description": "A natural user request or conversation snippet."
          },
          "binary_rubric": {
            "type": "string",
            "minLength": 20,
            "description": "A single, specific, binary-verifiable criterion. PASS or FAIL only."
          },
          "expected_difficulty": {
            "type": "string",
            "enum": ["easy", "medium", "hard"],
            "description": "Expected difficulty for the current skill version."
          }
        }
      }
    }
  }
}
